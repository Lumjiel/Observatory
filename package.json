{
  "name": "terminal-observatory",
  "version": "1.0.0",
  "description": "终端日志 · 实时观测站 - 个人学习数据监控中心",
  "type": "module",
  "scripts": {
    "dev": "node scripts/article-scanner.mjs && node scripts/github-scraper.mjs && eleventy --serve",
    "build": "node scripts/article-scanner.mjs && node scripts/github-scraper.mjs && eleventy",
    "fetch-github": "node scripts/github-scraper.mjs",
    "scan:articles": "node scripts/article-scanner.mjs",
    "import:article": "node scripts/article-importer.mjs",
    "new-article": "node scripts/new-article.mjs",
    "auto-update": "npm run scan:articles",
    "server": "node scripts/article-api.mjs"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "sanitize-html": "^2.17.3"
  },
  "keywords": [
    "blog",
    "terminal",
    "learning",
    "eleventy"
  ],
  "author": "student",
  "license": "MIT",
  "devDependencies": {
    "chokidar": "^5.0.0",
    "livereload": "^0.10.3"
  }
