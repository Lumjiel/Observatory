{
  "name": "terminal-observatory",
  "version": "1.0.0",
  "description": "终端日志 · 实时观测站 - 个人学习数据监控中心",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-js.mjs && node scripts/article-scanner.mjs && node scripts/github-scraper.mjs && eleventy --serve",
    "build": "node scripts/build-js.mjs && node scripts/article-scanner.mjs && node scripts/github-scraper.mjs && eleventy",
    "build:js": "node scripts/build-js.mjs",
    "fetch-github": "node scripts/github-scraper.mjs",
    "scan:articles": "node scripts/article-scanner.mjs",
    "import:article": "node scripts/article-importer.mjs",
    "new-article": "node scripts/new-article.mjs",
    "auto-update": "npm run scan:articles",
    "server": "node scripts/article-api.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop observatory",
    "pm2:restart": "pm2 restart observatory",
    "pm2:logs": "pm2 logs observatory",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "codemirror": "^6.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3"
  },
  "keywords": [
    "blog",
    "terminal",
    "learning",
    "eleventy"
  ],
  "author": "student",
  "license": "MIT",
  "devDependencies": {
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.0",
    "livereload": "^0.10.3",
    "pm2": "^7.0.1"
  }
}
