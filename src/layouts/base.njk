<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{{ title or "观测站 · 一个CS学生的实时学习宇宙" }}</title>
    <link rel="stylesheet" href="{{ env.BASE_PATH }}/assets/css/main.css">
    <link rel="alternate" type="application/atom+xml" title="Atom Feed" href="{{ env.BASE_PATH }}/feed.xml">
</head>
<body>
    <div class="particle-layer" id="particleLayer"></div>
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
        <span>📡 观测站加载中...</span>
    </div>

    <header class="status-bar">
        <div class="status-bar-left">
            <div class="logo-dot"></div>
            <span class="site-name">&gt; observatory<span class="highlight">.log</span></span>
        </div>
        <div class="status-bar-right">
            <span class="status-stat"><span class="val" id="uptime">--</span></span>
            <span class="status-stat">📡 信号 <span class="val" id="activeCount">--</span></span>
            <button id="themeToggle" class="theme-btn">🌙</button>
        </div>
    </header>

    <div class="main-container" id="mainContainer">
        <div class="cmd-card">
            <div class="cmd-card-row">
                <span class="prompt">$</span>
                <input type="text" class="cmd-input" id="cmdInput" placeholder="输入命令... (help 查看全部)" autofocus>
                <span class="cmd-hint">↑↓ 历史 | Tab 补全 | Enter 执行</span>
            </div>
            <div class="cmd-error" id="cmdError"></div>
        </div>

        <div class="signal-overview" id="signalOverview"></div>

        <div class="content-layout">
            <div class="main-content">
                {{ content | safe }}
            </div>

            <aside class="universe-sidebar">
                <div class="sidebar-card">
                    <h4>🌳 技能场强</h4>
                    <div id="skillList"></div>
                </div>
                <div class="sidebar-card">
                    <h4>📝 最近更新</h4>
                    <ul class="mini-log-list" id="recentErrors"></ul>
                </div>
                <div class="sidebar-card">
                    <h4>📡 宇宙回响</h4>
                    <div class="quote-box" id="randomQuote"></div>
                </div>
            </aside>
        </div>
    </div>


    <script>
        window.BASE_PATH = '{{ env.BASE_PATH }}';
        window.ARTICLES_DATA = {{ collections.articles | jsonify | safe }};
        window.SITE_DATA = {{ site | jsonify | safe }};
        window.GITHUB_DATA = {{ github | jsonify | safe }};
    </script>
    <script src="{{ env.BASE_PATH }}/assets/js/bundle.js" defer></script>
</body>
</html>
