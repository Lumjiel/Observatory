---
layout: base.njk
---
<div class="article-page">
    <div class="terminal-header">
        <span class="terminal-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
        </span>
        <span class="terminal-title">{{ article.slug }}.md</span>
    </div>

    <nav class="article-breadcrumb">
        <span class="prompt-icon">$</span>
        <a href="/">cd ~</a>
        <span class="separator">/</span>
        <a href="/articles/">articles</a>
        <span class="separator">/</span>
        <a href="/articles/{{ article.category }}/">{{ article.category }}</a>
        <span class="separator">/</span>
        <span class="current">{{ article.slug }}</span>
    </nav>

    <article class="article-container">
        <header class="article-header">
            <div class="article-title-wrap">
                <span class="title-prefix">#</span>
                <h1 class="article-title">{{ article.title }}</h1>
            </div>
            <div class="article-meta">
                <span class="meta-item">
                    <span class="meta-icon">📅</span>
                    <span class="meta-value">{{ article.date }}</span>
                </span>
                <span class="meta-item">
                    <span class="meta-icon">⏱</span>
                    <span class="meta-value">{{ article.readingTime }}</span>
                </span>
                <a href="/articles/{{ article.category }}/" class="meta-item meta-category">
                    <span class="meta-icon">📁</span>
                    <span class="meta-value">{{ article.category | categoryLabel }}</span>
                </a>
            </div>
            <div class="article-tags">
                {% for tag in article.tags %}
                <span class="tag">#{{ tag }}</span>
                {% endfor %}
            </div>
        </header>

        <div class="article-content">
            {{ content | safe }}
        </div>

        <footer class="article-footer">
            {% if article.source === 'log' and article.sourceLogId %}
            <section class="related-section">
                <div class="section-header">
                    <span class="section-icon">📎</span>
                    <h3>关联日志</h3>
                </div>
                <p class="related-desc">$ cat <code>{{ article.sourceLogId }}</code>.log</p>
            </section>
            {% endif %}

            <div class="article-nav">
                {% if prevArticle %}
                <a href="/articles/{{ prevArticle.category }}/{{ prevArticle.slug }}/" class="nav-link prev">
                    <span class="nav-arrow">←</span>
                    <span class="nav-label">prev</span>
                    <span class="nav-title">{{ prevArticle.title }}</span>
                </a>
                {% endif %}
                {% if nextArticle %}
                <a href="/articles/{{ nextArticle.category }}/{{ nextArticle.slug }}/" class="nav-link next">
                    <span class="nav-label">next</span>
                    <span class="nav-arrow">→</span>
                    <span class="nav-title">{{ nextArticle.title }}</span>
                </a>
                {% endif %}
            </div>

            <div class="article-end-marker">
                <span class="end-line">───</span>
                <span class="end-text">END OF ARTICLE</span>
                <span class="end-line">───</span>
            </div>
        </footer>
    </article>
</div>

<style>
.article-page {
    max-width: 850px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
}

/* Terminal-style header bar */
.terminal-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px 8px 0 0;
    padding: 0.6rem 1rem;
    margin-bottom: 0;
    border-bottom: none;
}

.terminal-dots {
    display: flex;
    gap: 0.4rem;
}

.terminal-dots .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

.terminal-dots .dot.red { background: #FF5F56; }
.terminal-dots .dot.yellow { background: #FFBD2E; }
.terminal-dots .dot.green { background: #27CA40; }

.terminal-title {
    font-size: 0.75rem;
    color: var(--gray);
    font-family: var(--font-mono);
}

/* Terminal-style breadcrumb */
.article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--gray);
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    padding: 0.6rem 1rem;
    font-family: var(--font-mono);
    margin-bottom: 0;
}

.prompt-icon {
    color: var(--green);
    font-weight: bold;
}

.article-breadcrumb a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color var(--transition);
}

.article-breadcrumb a:hover {
    color: var(--green);
}

.separator {
    color: var(--gray-dim);
}

.article-breadcrumb .current {
    color: var(--green);
}

/* Article container with terminal border */
.article-container {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 12px 12px;
    padding: 1.5rem 2rem;
    position: relative;
}

/* Decorative corner lines */
.article-container::before {
    content: '┌';
    position: absolute;
    top: -1px;
    left: -1px;
    color: var(--green-dim);
    font-size: 1rem;
}

.article-container::after {
    content: '┐';
    position: absolute;
    top: -1px;
    right: -1px;
    color: var(--green-dim);
    font-size: 1rem;
}

/* Article header */
.article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
}

.article-title-wrap {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.title-prefix {
    color: var(--green);
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.3;
}

.article-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
    font-family: var(--font-mono);
}

/* Meta info row */
.article-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.8rem;
    color: var(--gray);
    margin-bottom: 1rem;
    flex-wrap: wrap;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
}

.meta-icon {
    opacity: 0.7;
}

.meta-value {
    font-family: var(--font-mono);
}

.meta-category {
    color: var(--green);
    text-decoration: none;
}

.meta-category:hover {
    text-decoration: underline;
}

/* Tags */
.article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.tag {
    font-size: 0.75rem;
    color: var(--text-dim);
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    transition: all var(--transition);
}

.tag:hover {
    border-color: var(--green);
    color: var(--green);
}

/* Article content - terminal style */
.article-content {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text);
}

.article-content img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1em 0;
    border-radius: 4px;
}

.article-content h1,
.article-content h2,
.article-content h3 {
    color: var(--green);
    margin: 1.5em 0 0.8em 0;
    line-height: 1.4;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.article-content h1::before { content: '## '; color: var(--green-dim); }
.article-content h2::before { content: '### '; color: var(--gray-dim); }
.article-content h3::before { content: '#### '; color: var(--gray-dim); }

.article-content h2 { font-size: 1.2rem; }
.article-content h3 { font-size: 1rem; }

.article-content p {
    margin: 1em 0;
    font-family: var(--font-mono);
}

/* Code styling */
.article-content code {
    background: rgba(0, 0, 0, 0.4);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    color: var(--amber);
    font-size: 0.9em;
    font-family: var(--font-mono);
    border: 1px solid var(--border);
}

.article-content pre {
    background: rgba(0, 0, 0, 0.5);
    padding: 1rem 1.2rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.2em 0;
    border: 1px solid var(--border);
    position: relative;
}

.article-content pre::before {
    content: '$';
    position: absolute;
    top: 0.5rem;
    left: 0.6rem;
    color: var(--green-dim);
    font-size: 0.75rem;
}

.article-content pre code {
    background: none;
    padding: 0;
    border: none;
    color: var(--text);
    font-size: 0.85rem;
}

/* Lists */
.article-content ul,
.article-content ol {
    margin: 1em 0;
    padding-left: 1.5rem;
    font-family: var(--font-mono);
}

.article-content li {
    margin: 0.4em 0;
}

.article-content ul li::marker {
    color: var(--green);
}

.article-content ol li::marker {
    color: var(--amber);
}

/* Blockquote - terminal style */
.article-content blockquote {
    border-left: 3px solid var(--green);
    background: var(--bg);
    margin: 1.2em 0;
    padding: 0.8rem 1.2rem;
    color: var(--text-dim);
    font-style: italic;
    border-radius: 0 8px 8px 0;
}

.article-content blockquote::before {
    content: '> ';
    color: var(--green-dim);
}

.article-content strong {
    color: var(--amber);
    font-weight: 600;
}

.article-content a {
    color: var(--green);
    text-decoration: none;
    border-bottom: 1px dashed var(--green-dim);
    transition: all var(--transition);
}

.article-content a:hover {
    border-bottom-style: solid;
    background: rgba(0, 229, 160, 0.1);
}

/* Footer */
.article-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--border);
}

/* Related section */
.related-section {
    margin-bottom: 1.5rem;
    background: var(--bg);
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 1rem;
}

.section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
}

.section-icon {
    font-size: 0.9rem;
}

.related-section h3 {
    font-size: 0.85rem;
    color: var(--green);
    margin: 0;
}

.related-desc {
    font-size: 0.8rem;
    color: var(--gray);
    font-family: var(--font-mono);
    margin: 0;
}

.related-desc code {
    color: var(--amber);
    background: var(--surface);
    padding: 0.1em 0.4em;
    border-radius: 3px;
}

/* Navigation */
.article-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: all var(--transition);
    flex: 1;
    max-width: 45%;
}

.nav-link:hover {
    border-color: var(--green);
    background: rgba(0, 229, 160, 0.05);
}

.nav-link.next {
    justify-content: flex-end;
    text-align: right;
}

.nav-arrow {
    color: var(--green);
    font-size: 1rem;
}

.nav-label {
    font-size: 0.7rem;
    color: var(--gray-dim);
    text-transform: uppercase;
}

.nav-title {
    font-size: 0.8rem;
    color: var(--text-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 150px;
}

/* End marker - terminal style */
.article-end-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    color: var(--gray-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
}

.end-line {
    letter-spacing: -0.2em;
}

.end-text {
    color: var(--green-dim);
}

/* Mobile */
@media (max-width: 768px) {
    .article-page {
        padding: 0.8rem;
    }

    .article-container {
        padding: 1.2rem 1rem;
    }

    .article-title {
        font-size: 1.3rem;
    }

    .article-meta {
        gap: 1rem;
    }

    .article-nav {
        flex-direction: column;
    }

    .nav-link {
        max-width: 100%;
    }

    .nav-title {
        max-width: 100px;
    }
}
</style>