---
layout: base.njk
title: "标签归档"
permalink: /tags/
---

{% set currentTag = page.url | getQueryParam("tag") %}

{% if currentTag %}
  {% set taggedArticles = [] %}
  {% for article in collections.articles %}
    {% if article.tags and currentTag in article.tags %}
      {% set taggedArticles = taggedArticles.concat([article]) %}
    {% endif %}
  {% endfor %}
  {% set displayArticles = taggedArticles %}
{% else %}
  {% set displayArticles = [] %}
{% endif %}

<div class="articles-page">
    <div class="terminal-header">
        <span class="terminal-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
        </span>
        <span class="terminal-title">tags.sh</span>
    </div>

    <header class="page-header">
        <div class="command-line">
            <span class="prompt">$</span>
            <span class="command">grep -r "#{{ currentTag }}" ./articles/</span>
        </div>
        {% if currentTag %}
        <h1 class="page-title">#{{ currentTag }}</h1>
        <p class="page-subtitle">共 {{ displayArticles.length }} 篇相关文章</p>
        {% else %}
        <h1 class="page-title">🏷️ 标签归档</h1>
        <p class="page-subtitle">请在 URL 中指定标签</p>
        {% endif %}
    </header>

    <div class="articles-list">
        {% if currentTag %}
        {% for article in displayArticles %}
        <article class="article-card">
            <a href="/articles/{{ article.category }}/{{ article.slug }}/" class="article-link">
                <div class="article-meta-row">
                    <span class="article-category {{ article.category }}">{{ article.category | categoryLabel }}</span>
                    <span class="article-date">{{ article.date }}</span>
                    <span class="article-time">⏱ {{ article.readingTime }}</span>
                </div>
                <h2 class="article-title">
                    <span class="title-icon">📄</span>
                    {{ article.title }}
                </h2>
                <p class="article-excerpt">{{ article.excerpt }}</p>
                <div class="article-footer-row">
                    <div class="article-tags">
                        {% for tag in article.tags %}
                        <span class="tag">#{{ tag }}</span>
                        {% endfor %}
                    </div>
                    <span class="read-more">阅读 →</span>
                </div>
            </a>
        </article>
        {% endfor %}
        {% if displayArticles.length === 0 %}
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <p class="empty-message">暂无相关文章</p>
        </div>
        {% endif %}
        {% else %}
        <div class="empty-state">
            <div class="empty-icon">🏷️</div>
            <p class="empty-message">无标签参数</p>
            <p class="empty-hint">访问 /tags/?tag=标签名 查看该标签下的文章</p>
        </div>
        {% endif %}
    </div>

    <div class="page-footer">
        <span class="end-line">───</span>
        <span class="end-text">END</span>
        <span class="end-line">───</span>
    </div>
</div>

<style>
.articles-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
}
.terminal-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px 8px 0 0;
    padding: 0.6rem 1rem;
    border-bottom: none;
}
.terminal-dots { display: flex; gap: 0.4rem; }
.terminal-dots .dot { width: 12px; height: 12px; border-radius: 50%; }
.terminal-dots .dot.red { background: #FF5F56; }
.terminal-dots .dot.yellow { background: #FFBD2E; }
.terminal-dots .dot.green { background: #27CA40; }
.terminal-title { font-size: 0.75rem; color: var(--gray); font-family: var(--font-mono); }
.page-header {
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    padding: 1rem 1.5rem;
}
.command-line { font-family: var(--font-mono); font-size: 0.8rem; margin-bottom: 0.5rem; }
.command-line .prompt { color: var(--green); font-weight: bold; }
.command-line .command { color: var(--text-dim); }
.page-title { font-size: 1.4rem; color: var(--green); margin: 0.5rem 0 0.3rem 0; font-family: var(--font-mono); }
.page-subtitle { color: var(--gray); font-size: 0.8rem; font-family: var(--font-mono); }
.articles-list { display: flex; flex-direction: column; gap: 1rem; }
.article-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all var(--transition);
    position: relative;
}
.article-card::before {
    content: '│';
    position: absolute;
    left: -1px; top: -1px; bottom: -1px;
    color: var(--green-dim); font-size: 1rem; opacity: 0.3;
}
.article-card:hover { border-color: var(--border-active); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4); }
.article-card:hover::before { opacity: 0.8; color: var(--green); }
.article-link { display: block; padding: 1.2rem 1.5rem; text-decoration: none; color: inherit; }
.article-meta-row { display: flex; gap: 1rem; align-items: center; margin-bottom: 0.6rem; }
.article-category { font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 3px; text-transform: uppercase; font-weight: 600; }
.article-category.tech { color: var(--green); background: rgba(0, 229, 160, 0.1); }
.article-category.reading { color: var(--blue); background: rgba(77, 184, 255, 0.1); }
.article-category.projects { color: var(--amber); background: rgba(255, 179, 0, 0.1); }
.article-category.essays { color: var(--magenta); background: rgba(255, 107, 157, 0.1); }
.article-date { font-size: 0.75rem; color: var(--gray-dim); font-family: var(--font-mono); }
.article-time { font-size: 0.75rem; color: var(--gray); font-family: var(--font-mono); margin-left: auto; }
.article-title { display: flex; align-items: center; gap: 0.5rem; font-size: 1.05rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; line-height: 1.4; font-family: var(--font-mono); }
.title-icon { font-size: 1rem; opacity: 0.6; }
.article-card:hover .article-title { color: var(--green); }
.article-excerpt { font-size: 0.85rem; color: var(--text-dim); margin-bottom: 0.8rem; line-height: 1.6; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; font-family: var(--font-mono); }
.article-footer-row { display: flex; justify-content: space-between; align-items: center; }
.article-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.tag { font-size: 0.7rem; color: var(--text-dim); font-family: var(--font-mono); }
.read-more { font-size: 0.75rem; color: var(--green); font-family: var(--font-mono); opacity: 0; transition: opacity var(--transition); }
.article-card:hover .read-more { opacity: 1; }
.empty-state { text-align: center; padding: 3rem 1rem; background: var(--surface); border: 1px dashed var(--border); border-radius: 8px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.5; }
.empty-message { color: var(--gray); font-size: 1rem; margin-bottom: 0.5rem; }
.empty-hint { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-dim); line-height: 1.8; }
.empty-hint .prompt { color: var(--green); }
.empty-hint .comment { color: var(--gray-dim); }
.page-footer { display: flex; align-items: center; justify-content: center; gap: 0.8rem; color: var(--gray-dim); font-family: var(--font-mono); font-size: 0.7rem; margin-top: 2rem; }
.end-line { letter-spacing: -0.2em; }
.end-text { color: var(--green-dim); }
@media (max-width: 768px) {
    .articles-page { padding: 0.8rem; }
    .article-link { padding: 1rem; }
    .article-meta-row { flex-wrap: wrap; }
    .article-time { margin-left: 0; width: 100%; }
}
</style>
