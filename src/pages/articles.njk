---
layout: base.njk
title: "文章列表"
permalink: /articles/
---

{% set currentCategory = page.url | getQueryParam("category") %}

{% if currentCategory %}
  {% set filteredArticles = [] %}
  {% for article in collections.articles %}
    {% if article.category == currentCategory %}
      {% set filteredArticles = filteredArticles.concat([article]) %}
    {% endif %}
  {% endfor %}
  {% set displayArticles = filteredArticles %}
{% else %}
  {% set displayArticles = collections.articles %}
{% endif %}

<div class="articles-page">
    <div class="terminal-header">
        <span class="terminal-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
        </span>
        <span class="terminal-title">articles.sh</span>
    </div>

    <header class="page-header">
        <div class="command-line">
            <span class="prompt">$</span>
            <span class="command">ls -la ./articles/</span>
        </div>
        <h1 class="page-title">📚 文章列表</h1>
        <p class="page-subtitle">共找到 {{ displayArticles.length }} 篇文章</p>
    </header>

    <div class="category-tabs">
        <a href="/articles/" class="tab {% if not currentCategory %}active{% endif %}">
            <span class="tab-icon">📂</span>
            <span class="tab-label">全部</span>
            <span class="tab-count">{{ collections.articles.length }}</span>
        </a>
        {% set techCount = 0 %}
        {% for a in collections.articles %}
            {% if a.category == 'tech' %}{% set techCount = techCount + 1 %}{% endif %}
        {% endfor %}
        <a href="/articles/?category=tech" class="tab {% if currentCategory == 'tech' %}active{% endif %}">
            <span class="tab-icon">🛠️</span>
            <span class="tab-label">技术</span>
            <span class="tab-count">{{ techCount }}</span>
        </a>
        {% set readingCount = 0 %}
        {% for a in collections.articles %}
            {% if a.category == 'reading' %}{% set readingCount = readingCount + 1 %}{% endif %}
        {% endfor %}
        <a href="/articles/?category=reading" class="tab {% if currentCategory == 'reading' %}active{% endif %}">
            <span class="tab-icon">📖</span>
            <span class="tab-label">读书</span>
            <span class="tab-count">{{ readingCount }}</span>
        </a>
        {% set projectsCount = 0 %}
        {% for a in collections.articles %}
            {% if a.category == 'projects' %}{% set projectsCount = projectsCount + 1 %}{% endif %}
        {% endfor %}
        <a href="/articles/?category=projects" class="tab {% if currentCategory == 'projects' %}active{% endif %}">
            <span class="tab-icon">🚀</span>
            <span class="tab-label">项目</span>
            <span class="tab-count">{{ projectsCount }}</span>
        </a>
        {% set essaysCount = 0 %}
        {% for a in collections.articles %}
            {% if a.category == 'essays' %}{% set essaysCount = essaysCount + 1 %}{% endif %}
        {% endfor %}
        <a href="/articles/?category=essays" class="tab {% if currentCategory == 'essays' %}active{% endif %}">
            <span class="tab-icon">✍️</span>
            <span class="tab-label">随笔</span>
            <span class="tab-count">{{ essaysCount }}</span>
        </a>
    </div>

    <div class="articles-list">
        {% for article in displayArticles %}
        <article class="article-card">
            <a href="/articles/{{ article.category }}/{{ article.slug }}/" class="article-link">
                <div class="article-meta-row">
                    <span class="article-category {{ article.category }}">{{ article.category | categoryLabel }}</span>
                    <span class="article-date">{{ article.date }}</span>
                    <span class="article-time">⏱ {{ article.readingTime }}</span>
                </div>
                <h2 class="article-title">
                    <span class="title-icon">📄</span>
                    {{ article.title }}
                </h2>
                <p class="article-excerpt">{{ article.excerpt }}</p>
                <div class="article-footer-row">
                    <div class="article-tags">
                        {% for tag in article.tags %}
                        <span class="tag">#{{ tag }}</span>
                        {% endfor %}
                    </div>
                    <span class="read-more">阅读 →</span>
                </div>
            </a>
        </article>
        {% endfor %}

        {% if collections.articles.length === 0 %}
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <p class="empty-message">暂无文章</p>
            <p class="empty-hint">
                <span class="prompt">$</span> mkdir src/articles/{category}/<br>
                <span class="comment"># 将 Markdown 文件放入分类目录即可自动导入</span>
            </p>
        </div>
        {% endif %}
    </div>

    <div class="page-footer">
        <span class="end-line">───</span>
        <span class="end-text">END OF LIST</span>
        <span class="end-line">───</span>
    </div>
</div>

<style>
.articles-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
}

/* Terminal header */
.terminal-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px 8px 0 0;
    padding: 0.6rem 1rem;
    margin-bottom: 0;
    border-bottom: none;
}

.terminal-dots {
    display: flex;
    gap: 0.4rem;
}

.terminal-dots .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

.terminal-dots .dot.red { background: #FF5F56; }
.terminal-dots .dot.yellow { background: #FFBD2E; }
.terminal-dots .dot.green { background: #27CA40; }

.terminal-title {
    font-size: 0.75rem;
    color: var(--gray);
    font-family: var(--font-mono);
}

/* Page header */
.page-header {
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: none;
    padding: 1rem 1.5rem;
    margin-bottom: 0;
}

.command-line {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
}

.command-line .prompt {
    color: var(--green);
    font-weight: bold;
}

.command-line .command {
    color: var(--text-dim);
}

.page-title {
    font-size: 1.4rem;
    color: var(--green);
    margin: 0.5rem 0 0.3rem 0;
    font-family: var(--font-mono);
}

.page-subtitle {
    color: var(--gray);
    font-size: 0.8rem;
    font-family: var(--font-mono);
}

/* Category tabs */
.category-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0 0 8px 8px;
    padding: 0.8rem 1rem;
}

.tab {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--gray);
    text-decoration: none;
    font-size: 0.8rem;
    transition: all var(--transition);
    font-family: var(--font-mono);
}

.tab:hover,
.tab.active {
    border-color: var(--green);
    color: var(--green);
    background: rgba(0, 229, 160, 0.05);
}

.tab-icon {
    font-size: 0.9rem;
}

.tab-label {
    font-weight: 500;
}

.tab-count {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    background: var(--bg);
    border-radius: 10px;
    color: var(--text-dim);
}

.tab.active .tab-count {
    background: var(--green);
    color: var(--bg);
}

/* Articles list */
.articles-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.article-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all var(--transition);
    position: relative;
}

/* Decorative corner */
.article-card::before {
    content: '│';
    position: absolute;
    left: -1px;
    top: -1px;
    bottom: -1px;
    color: var(--green-dim);
    font-size: 1rem;
    opacity: 0.3;
}

.article-card:hover {
    border-color: var(--border-active);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
}

.article-card:hover::before {
    opacity: 0.8;
    color: var(--green);
}

.article-link {
    display: block;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    color: inherit;
}

.article-meta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.6rem;
}

.article-category {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    text-transform: uppercase;
    font-weight: 600;
}

.article-category.tech { color: var(--green); background: rgba(0, 229, 160, 0.1); }
.article-category.reading { color: var(--blue); background: rgba(77, 184, 255, 0.1); }
.article-category.projects { color: var(--amber); background: rgba(255, 179, 0, 0.1); }
.article-category.essays { color: var(--magenta); background: rgba(255, 107, 157, 0.1); }

.article-date {
    font-size: 0.75rem;
    color: var(--gray-dim);
    font-family: var(--font-mono);
}

.article-time {
    font-size: 0.75rem;
    color: var(--gray);
    font-family: var(--font-mono);
    margin-left: auto;
}

.article-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.4;
    font-family: var(--font-mono);
}

.title-icon {
    font-size: 1rem;
    opacity: 0.6;
}

.article-card:hover .article-title {
    color: var(--green);
}

.article-excerpt {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 0.8rem;
    line-height: 1.6;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    font-family: var(--font-mono);
}

.article-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.article-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
}

.tag {
    font-size: 0.7rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
}

.read-more {
    font-size: 0.75rem;
    color: var(--green);
    font-family: var(--font-mono);
    opacity: 0;
    transition: opacity var(--transition);
}

.article-card:hover .read-more {
    opacity: 1;
}

/* Empty state */
.empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 8px;
}

.empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.empty-message {
    color: var(--gray);
    font-size: 1rem;
    margin-bottom: 0.5rem;
}

.empty-hint {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.8;
}

.empty-hint .prompt {
    color: var(--green);
}

.empty-hint .comment {
    color: var(--gray-dim);
}

/* Page footer */
.page-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    color: var(--gray-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    margin-top: 2rem;
}

.end-line {
    letter-spacing: -0.2em;
}

.end-text {
    color: var(--green-dim);
}

/* Mobile */
@media (max-width: 768px) {
    .articles-page {
        padding: 0.8rem;
    }

    .article-link {
        padding: 1rem;
    }

    .article-meta-row {
        flex-wrap: wrap;
    }

    .article-time {
        margin-left: 0;
        width: 100%;
    }
}
</style>